# Copy this file to .env before running docker compose if you want to override
# the default local deployment settings. Keep .env private; it may contain
# passwords and secrets.

# PRISM_IMAGE_TAG=latest

# Leave SECRET unset to let Prism generate and persist a random secret in
# ./config/config.yaml on first startup.
# SECRET=replace_with_a_random_32_byte_string

# Optional root login password for the first empty-database startup. Leave unset
# to generate a random password and read it from docker compose logs.
# ROOT_INITIAL_PASSWORD=replace_with_a_strong_initial_password

# MySQL settings shared by the mysql and prism services.
# MYSQL_ROOT_PASSWORD=replace_with_a_strong_mysql_root_password
# MYSQL_DATABASE=chatnio
# MYSQL_USER=chatnio
# MYSQL_PASSWORD=replace_with_a_strong_mysql_user_password
